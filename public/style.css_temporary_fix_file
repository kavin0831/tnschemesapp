/* Dashboard UI */
.dashboard-grid {
    display: grid;
    grid-template-columns: 1fr 2fr 2fr;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
}

.dash-card {
    background: white;
    padding: 1.5rem;
    border-radius: 15px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
}

.dash-card:hover {
    transform: translateY(-5px);
}

.dash-card h3 {
    font-size: 1rem;
    color: var(--secondary-color);
    margin-bottom: 1rem;
    font-weight: 600;
}

.result-summary {
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, var(--secondary-color) 0%, #1e3c72 100%);
    color: white;
}

.stat-main {
    text-align: center;
}

.stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
}

.stat-label {
    font-size: 1rem;
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.chart-container {
    min-height: 250px;
    display: flex;
    flex-direction: column;
}

.chart-container canvas {
    max-height: 200px;
}

.results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #eee;
}

.results-header h2 {
    font-size: 1.8rem;
    color: var(--secondary-color);
}

@media (max-width: 992px) {
    .dashboard-grid {
        grid-template-columns: 1fr;
    }
}

/* Floating AI Chat Button */
.floating-chat-btn {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    padding: 1rem 1.5rem;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
    z-index: 999;
    transition: transform 0.2s, box-shadow 0.2s;
}

.floating-chat-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 30px rgba(102, 126, 234, 0.5);
}

/* Chat Modal */
.chat-modal {
    max-width: 500px;
    height: 70vh;
    display: flex;
    flex-direction: column;
}

.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 8px;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
}

.ai-message,
.user-message {
    padding: 1rem;
    border-radius: 15px;
    margin-bottom: 1rem;
    max-width: 90%;
    font-size: 0.95rem;
    line-height: 1.5;
    position: relative;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}

.ai-message {
    background: white;
    color: #000;
    align-self: flex-start;
    border-bottom-left-radius: 2px;
    border: 1px solid #e9ecef;
}

.user-message {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    align-self: flex-end;
    border-bottom-right-radius: 2px;
}

.ai-message ul {
    margin: 0.5rem 0 0 1rem;
    padding: 0;
}

.chat-input-area {
    display: flex;
    gap: 0.5rem;
}

.chat-input-area input {
    flex: 1;
}

.close-chat {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-size: 2rem;
    cursor: pointer;
    color: #666;
}

.typing-indicator {
    font-style: italic;
    color: #666;
    font-size: 0.85rem;
}
